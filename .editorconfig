# EditorConfig keeps indentation and line endings consistent across apps,
# the API server, and shared packages regardless of each developer's editor.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
