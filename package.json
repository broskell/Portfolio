{
  "name": "portfolio-cms-ecosystem",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo foundation for a portfolio, admin dashboard, Express API, and shared packages.",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@portfolio/portfolio --filter=@portfolio/dashboard --filter=@portfolio/server",
    "dev:portfolio": "pnpm --filter @portfolio/portfolio dev",
    "dev:dashboard": "pnpm --filter @portfolio/dashboard dev",
    "dev:server": "pnpm --filter @portfolio/server dev",
    "build": "turbo run build",
    "build:portfolio": "pnpm --filter @portfolio/portfolio build",
    "build:dashboard": "pnpm --filter @portfolio/dashboard build",
    "start:server": "pnpm --filter @portfolio/server start",
    "seed": "pnpm --filter @portfolio/server seed",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "eslint": "^9.16.0",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "bcrypt"
    ]
  }
}
